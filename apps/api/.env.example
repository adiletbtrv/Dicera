PORT=3001
NODE_ENV=development

# Database (Supabase or any Postgres)
DATABASE_URL=postgresql://user:password@localhost:5432/dnd_platform

# Auth (Supabase or custom JWT)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRY=7d

# Supabase (optional, if using Supabase hosted Postgres)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key

# AI Providers (use at least one)
OPENAI_API_KEY=sk-...
HUGGINGFACE_API_KEY=hf_...
GEMINI_API_KEY=AIza...

# AI Configuration
AI_PROVIDER=gemini
AI_DEFAULT_MODEL=gemini-1.5-flash
AI_EMBEDDING_MODEL=text-embedding-004
AI_MAX_REQUESTS_PER_MINUTE=5
AI_MAX_REQUESTS_PER_DAY=50

# Storage (for map images, character avatars)
# Option A: Supabase Storage (free tier)
STORAGE_PROVIDER=supabase
# Option B: Cloudflare R2 (free tier)
# STORAGE_PROVIDER=r2
# R2_ACCOUNT_ID=...
# R2_ACCESS_KEY=...
# R2_SECRET_KEY=...
# R2_BUCKET=dnd-platform

# CORS
CORS_ORIGIN=http://localhost:3000
